  "show_section_headings": 0,
  "standard": "No",
  "html": "<div style=\"direction:rtl;text-align:center;margin-bottom:14px;\"><h2 style=\"font-size:20px;font-weight:700;margin:0 0 10px 0;\">تقرير جدول الجلسات</h2><p style=\"font-size:15px;line-height:1.85;margin:0;\"><span style=\"font-weight:700;\">رقم الملف:</span> <span style=\"font-weight:600;\">{{ doc.name }}</span> &nbsp;&nbsp; <span style=\"font-weight:700;\">اسم الموكل:</span> <span style=\"font-weight:600;\">{{ doc.customer_name or \"\" }}</span></p></div><table class=\"table table-bordered\" style=\"width:100%;direction:rtl;font-size:12px;\"><thead><tr><th style=\"width:9%;\">تاريخ الجلسة</th><th style=\"width:10%;\">المحكمة</th><th style=\"width:6%;\">الدرجة</th><th style=\"width:8%;\">رقم القضية</th><th style=\"width:6%;\">الدائرة</th><th style=\"width:10%;\">موضوع القضية</th><th style=\"width:7%;\">صفة الموكل</th><th style=\"width:8%;\">الخصم</th><th style=\"width:7%;\">صفة الخصم</th><th style=\"width:9%;\">القرار السابق</th><th style=\"width:15%;\">قرار الجلسة</th><th style=\"width:5%;\">تاريخ الجلسة القادمة</th></tr></thead><tbody>{% for row in doc.case_sessions %}<tr><td style=\"font-weight:600;font-size:13px;\">{{ row.business_on_date or \"\" }}</td><td>{{ row.court or \"\" }}</td><td>{{ row.litigation_degree or \"\" }}</td><td>{{ row.case_number or \"\" }}</td><td style=\"font-size:11px;\">{{ row.chamber or \"\" }}</td><td>{{ row.case_subject or \"\" }}</td><td>{{ row.client_capacity or \"\" }}</td><td>{{ row.opponent or \"\" }}</td><td>{{ row.opponent_capacity or \"\" }}</td><td>{{ row.previous_decision or \"\" }}</td><td style=\"font-size:13px;\">{{ row.decision or \"\" }}</td><td style=\"font-weight:600;font-size:13px;\">{{ row.next_date or \"\" }}</td></tr>{% endfor %}</tbody></table>"
 },
